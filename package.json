{
  "name": "egyptian-dominos",
  "version": "1.0.0",
  "description": "Egyptian Dominoes - Classic domino game with Singles and Teams modes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.amourous.dominos",
    "productName": "Egyptian Dominoes",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/images/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Egyptian Dominoes"
    }
  },
  "keywords": [
    "dominoes",
    "game",
    "egyptian"
  ],
  "author": "Amourous",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
